# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
/.next/
/out/

# Production / bundles
/build
/dist

# Testing
/coverage
.nyc_output

# Vercel (tokens y enlaces locales de deploy)
.vercel

# Entorno — nunca commitear secretos (DATABASE_URL, API keys, etc.)
.env
.env.*
!.env.example
.envrc
.direnv/

# Logs & depuración
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# TypeScript (artefactos; next-env.d.ts lo regenera Next al instalar / dev)
*.tsbuildinfo
next-env.d.ts

# Turbopack / Turborepo (si los usas)
.turbo

# ESLint caché
.eslintcache

# Sistema operativo
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs (JetBrains; VS Code / Cursor suele commitearse si quieres settings del equipo)
.idea/

# Editores
*.swp
*.swo
*~

# Claves / certificados locales
*.pem
*.key

# Bases de datos locales de prueba (el proyecto usa Postgres en la nube)
*.db
*.sqlite
*.sqlite3

# Prisma: se commitea prisma/schema.prisma y prisma/migrations/ — no los ignores.

# Playwright / E2E (por si los añades luego)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
