generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformType {
  SPOTIFY
  YOUTUBE
  INSTAGRAM
  TIKTOK
  FACEBOOK
  WEBSITE
  OTHER
}

model Project {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  tagline    String?
  imageUrl   String?
  accentHex  String   @default("#e11d48")
  styleTag   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  platforms Platform[]
  resources ResourceLink[]
  notes     QuickNote[]
}

model Platform {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      PlatformType
  label     String?
  url       String
  sortOrder Int          @default(0)

  @@index([projectId])
}

model ResourceLink {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  url       String
  sortOrder Int     @default(0)

  @@index([projectId])
}

model QuickNote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content   String
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([projectId])
}
